{
  "name": "commons",
  "version": "1.0.0",
  "description": "Cerberus Common Library",
  "private": true,
  "type": "commonjs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./services/cryptoService": {
      "types": "./dist/services/cryptoService.d.ts",
      "default": "./dist/services/cryptoService.js"
    },
    "./services/cerberusPayService": {
      "types": "./dist/services/cerberusPayService.d.ts",
      "default": "./dist/services/cerberusPayService.js"
    },
    "./services/uniswapService": {
      "types": "./dist/services/uniswapService.d.ts",
      "default": "./dist/services/uniswapService.js"
    },
    "./services/uniswapTypes": {
      "types": "./dist/services/uniswapTypes.d.ts",
      "default": "./dist/services/uniswapTypes.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && npm run copy-assets",
    "prisma:generate": "prisma generate",
    "copy-assets": "powershell -Command \"Copy-Item src\\services\\*.json dist\\services -Force\""
  },
  "keywords": [],
  "author": "Blue Alien",
  "license": "MIT",
  "devDependencies": {
    "@types/aes-js": "^3.1.4",
    "@types/dotenv": "^6.1.1",
    "prisma": "^6.19.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@prisma/client": "^6.19.0",
    "aes-js": "^3.1.2",
    "axios": "^1.13.5",
    "dotenv": "^16.6.1",
    "ethers": "^6.16.0"
  }
}
